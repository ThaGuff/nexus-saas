# ── NEXUS SAAS · ENVIRONMENT ─────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://your-domain.up.railway.app

# Auth
JWT_SECRET=replace-with-64-char-random-string
JWT_EXPIRES_IN=7d

# Stripe (billing)
# Get from: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_ID=price_your-monthly-price-id

# Trial settings
TRIAL_DAYS=14
SUBSCRIPTION_PRICE_USD=2999

# AI Engine (Gemini Flash — FREE)
# Get from: aistudio.google.com → Get API Key
GEMINI_API_KEY=AIza-your-key

# Market Data (Binance public — no key needed)

# Admin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-this-immediately

# Dashboard secret for internal API
DASHBOARD_SECRET=nexus-internal-secret-2024

# ── Supabase (required) ───────────────────────────────────────────────────────
# Get from: supabase.com → your project → Settings → API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGc...your-service-role-key
